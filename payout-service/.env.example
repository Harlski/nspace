PORT=3091
HOST=127.0.0.1
PAYOUT_SERVICE_API_SECRET=your-long-random-secret
# Game server base URL for nim_payout_sent analytics callbacks (Compose default: http://nspace:3001)
#GAME_SERVER_INTERNAL_URL=http://127.0.0.1:3001
NIM_PAYOUT_DATA_DIR=./data
NIM_PAYOUT_PRIVATE_KEY=
NIM_NETWORK=testalbatross
NIM_PAYOUT_TX_MESSAGE=You mined NIM on Nimiq.Space!

# Polling interval for the payout worker (ms)
# NIM_PAYOUT_PROCESS_INTERVAL_MS=2000

# Skip hitting Nimiq for balance if a fresh value exists (reduces load)
# NIM_BALANCE_CACHE_MS=20000

# Max backoff between retries (ms)
# NIM_PAYOUT_MAX_BACKOFF_MS=3600000

# After this many failed send attempts, job moves to dead-letter file
# NIM_PAYOUT_DEAD_LETTER_ATTEMPTS=80

# Step-by-step console timeline for each payout send — see docs/nim-payout-tracing.md
# NIM_PAYOUT_TX_TRACE=1

# Light client log level: trace|debug|info|warn|error (use error in Docker to reduce noise)
# NIM_CLIENT_LOG_LEVEL=warn

# Max wait for tx inclusion (ms)
# NIM_TX_CONFIRM_TIMEOUT_MS=120000
