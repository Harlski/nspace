PORT=3091
HOST=127.0.0.1
PAYOUT_SERVICE_API_SECRET=dev-insecure-local-payout-secret
# Game server base URL for nim_payout_sent analytics callbacks (Compose default: http://nspace:3001)
#GAME_SERVER_INTERNAL_URL=http://127.0.0.1:3001
NIM_PAYOUT_DATA_DIR=./data
NIM_PAYOUT_PRIVATE_KEY=
NIM_NETWORK=testalbatross
NIM_PAYOUT_TX_MESSAGE=You mined NIM on Nimiq.Space!

# Polling interval for the payout worker (ms)
# NIM_PAYOUT_PROCESS_INTERVAL_MS=2000

# Skip hitting Nimiq for balance if a fresh value exists (reduces load)
# NIM_BALANCE_CACHE_MS=20000

# Max backoff between retries (ms)
# NIM_PAYOUT_MAX_BACKOFF_MS=3600000

# After this many failed send attempts, job moves to dead-letter file
# NIM_PAYOUT_DEAD_LETTER_ATTEMPTS=80

# Auto bulk-combine pending jobs per recipient when the oldest job has waited this long (ms).
# Default 28800000 (8 hours). Set 0 to disable (manual / end-of-day flush only).
# NIM_PAYOUT_AUTO_BULK_AFTER_MS=28800000

# How often to scan for stale pending jobs eligible for auto bulk (ms). Default 300000 (5 min).
# NIM_PAYOUT_AUTO_BULK_CHECK_MS=300000

# How often to reconcile broadcast-but-unconfirmed payouts against the chain (ms).
# Default 60000 (1 min). Set 0 to disable the reconciliation pass.
# NIM_PAYOUT_RECONCILE_INTERVAL_MS=60000

# How long a broadcast payout may stay unconfirmed before it is escalated to manual
# review (nim-payout-needs-review.jsonl) instead of being re-queued. Must exceed the
# on-chain validity window (~2h). Default 10800000 (3 hours).
# NIM_PAYOUT_UNCONFIRMED_REVIEW_MS=10800000

# Light client log level: trace|debug|info|warn|error (use error in Docker to reduce noise)
# NIM_CLIENT_LOG_LEVEL=warn

# Max wait for tx inclusion before a broadcast is parked as unconfirmed (ms)
# NIM_TX_CONFIRM_TIMEOUT_MS=120000
