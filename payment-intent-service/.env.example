# Copy to repo root .env or server/.env when using Docker Compose profile `payment`.

# Shared secret for `Authorization: Bearer …` on all /v1/* routes (generate a long random string).
PAYMENT_INTENT_API_SECRET=CHANGE_ME

# Hot wallet that receives incoming NIM (user-friendly address).
PAYMENT_INTENT_RECIPIENT_ADDRESS=NQ_PLACEHOLDER_REPLACE_ME

# Same Nimiq network name as the main server (`testalbatross`, `mainalbatross`, …).
NIM_NETWORK=testalbatross

# Optional
# PORT=3090
# PAYMENT_INTENT_SQLITE_PATH=./data/payment-intents.sqlite
# PAYMENT_INTENT_TTL_MS=1800000
# PAYMENT_INTENT_MIN_CONFIRMATIONS=1
# NIM_CLIENT_LOG_LEVEL=warn
