# Server environment variables
# Copy this file to .env for local development

# REQUIRED: Secret for signing JWT tokens (use a long random string in production)
JWT_SECRET=dev-insecure-change-me

# DEVELOPMENT ONLY: Set to "1" to bypass Nimiq wallet authentication
# NEVER use this in production!
DEV_AUTH_BYPASS=1

# Comma-separated Nimiq wallet addresses allowed for cinema observer mode (?stream=1).
# Required for full-board stream capture; leave unset to disable stream observer for all wallets.
# STREAM_OBSERVER_ADDRESSES=NQXX XXXX XXXX XXXX XXXX XXXX XXXX XXXX XXXX

# HTTP server port (default: 3001)
PORT=3001

# Verbose `[movement]` logs for pathfinding / recovery / tile crossings (set to 1 for local debugging).
# NSPACE_DEBUG_MOVEMENT=1

# Optional JSON store for in-game public profile messages (default: server/data/player-profiles.json).
# PLAYER_PROFILE_STORE_FILE=/var/lib/nspace/player-profiles.json
# PLAYER_LAST_SESSION_STORE_FILE=/var/lib/nspace/player-last-sessions.json

# Optional JSON store for username-set bans and channel mutes (default: server/data/moderation.json).
# MODERATION_STORE_FILE=/var/lib/nspace/moderation.json

# Optional JSON for `/admin/settings` toggles (default: server/data/admin-runtime-settings.json).
# ADMIN_RUNTIME_SETTINGS_FILE=/var/lib/nspace/admin-runtime-settings.json

# Optional append-only Pixel room paint history for timelapse (default: server/data/pixel/paint-log.jsonl).
# PIXEL_PAINT_LOG_FILE=/var/lib/nspace/pixel/paint-log.jsonl

# Optional JSON for login streak persistence (default: server/data/login-streaks.json).
# LOGIN_STREAK_STORE_FILE=/var/lib/nspace/login-streaks.json

# Optional JSON for in-game header marquee admin toggles + news text (default: server/data/header-marquee-settings.json).
# HEADER_MARQUEE_SETTINGS_FILE=/var/lib/nspace/header-marquee-settings.json

# Number of NPC bots per room (0-32, default: 2)
# Set to 0 to disable NPCs
FAKE_PLAYER_COUNT=2

# Max player-owned custom rooms per wallet (1–256, default 3). Raise for subscribers / tiers later.
# MAX_OWNED_ROOMS_PER_PLAYER=3

# --- In-game feedback (tickets + optional Telegram ping) ---
# Tickets persist to server/data/feedback/tickets.json (override with FEEDBACK_STORE_FILE).
# Player APIs: POST /api/feedback, GET /api/feedback/mine, GET /api/feedback/:id, POST /api/feedback/:id/messages
# Admin hub: /admin/feedback (JWT admin wallet) — reply, status, NIM reward on integrated tickets.
# Optional Telegram ping on new tickets (store is source of truth):
# Create a bot with @BotFather, add it to your group/channel, send any message in that chat,
# then read chat id from https://api.telegram.org/bot<token>/getUpdates (field result[].message.chat.id).
# Supergroup ids look like -100xxxxxxxxxx. "Bad Request: chat not found" = wrong id or bot not in chat.
#TELEGRAM_BOT_TOKEN=
#TELEGRAM_CHAT_ID=
#FEEDBACK_STORE_FILE=/var/lib/nspace/feedback/tickets.json

# Optional end-of-day stats report to Telegram (UTC). Sent shortly after 00:00 UTC for the day
# that just ended: unique sign-ins, new users, Nimiq Pay vs other, NIM paid out, active in-game
# time (capped-gap estimate, excludes long AFK). Reuses TELEGRAM_BOT_TOKEN/TELEGRAM_CHAT_ID.
# Enabled by default when Telegram is configured; set to 0/false to disable, 1/true to force on.
#DAILY_STATS_TELEGRAM_ENABLED=1
# Optional: send the daily report to a different chat than TELEGRAM_CHAT_ID.
#DAILY_STATS_TELEGRAM_CHAT_ID=
# How many days of event logs to scan when deciding "new users" (first-ever session_start). Default 400.
#DAILY_STATS_LOOKBACK_DAYS=400

# --- Payment intent sidecar (optional; /admin/system monitoring + /advertise funding) ---
# Base URL where the payment-intent HTTP service listens (local: npm run dev:payment-intent).
PAYMENT_INTENT_SERVICE_URL=http://127.0.0.1:3090
# Same bearer secret as payment-intent-service (literal string — do not use $(openssl …) here).
#PAYMENT_INTENT_API_SECRET=your-long-random-secret

# Optional: Payout Service sidecar (outgoing NIM rewards — required for claim payouts in production)
# Local dev: npm run dev:payout in another terminal, then point here.
PAYOUT_SERVICE_URL=http://127.0.0.1:3091
# Same bearer secret as payout-service (literal string — do not use $(openssl …) here).
#PAYOUT_SERVICE_API_SECRET=your-long-random-secret

# Claim fund-gating reads a locally cached balance pulled from the Payout Service (no network on hot path).
# NIM_CLAIM_BALANCE_PEEK_MAX_MS=30000
# NIM_BALANCE_CACHE_MS=20000
# NIM_BALANCE_BACKGROUND_REFRESH_MS=45000
# HTTP GET /api/nim/payout-balance: max wait before 503 (consensus can be slow)
# NIM_BALANCE_API_TIMEOUT_MS=28000
# If live read times out, return last cached balance when younger than this (ms); 0 disables
# NIM_BALANCE_API_STALE_MAX_MS=300000

# End-of-day auto-payout: at the end of each UTC day, combine each recipient's pending jobs
# into one on-chain transfer (same as admin "Payout in full") and clear the queue. Runs from
# the daily-stats scheduler (~00:02 UTC) AFTER the stats report is sent.
# Defaults ON when PAYOUT_SERVICE_* is configured; 0/false disables, 1/true forces on.
# NIM_PAYOUT_DAILY_FLUSH_ENABLED=1

# Durable Pay-Intent outbox (undelivered intents survive game-server restart).
# PAYOUT_OUTBOX_DIR=./data/payout-outbox
# PAYOUT_OUTBOX_DELIVERY_INTERVAL_MS=2000

# --- Mini-app billboard campaigns (/advertise) ---
# Default slot price 10 NIM unless BILLBOARD_SLOT_NIM_LUNA is set (payment-intent service reads the same vars).
#BILLBOARD_SLOT_NIM=10
#BILLBOARD_SLOT_DURATION_DAYS=7
#CAMPAIGN_STORE_SQLITE_PATH=./data/campaigns.sqlite
# Uploaded billboard images (default: ./data/advertise-uploads next to campaigns.sqlite)
#CAMPAIGN_UPLOAD_DIR=./data/advertise-uploads
# Prepaid on-screen rate: default 400 NIM ≈ 24h full-audience on-screen time (override with CAMPAIGN_NIM_PER_24H_VISIBLE or CAMPAIGN_VISIBILITY_NIM_PER_MINUTE)
#CAMPAIGN_NIM_PER_24H_VISIBLE=400

# Payout signer key, queue worker, and on-chain send tuning: see payout-service/.env.example
# (NIM_PAYOUT_PRIVATE_KEY must NOT be set on the game server.)

# Post-cutover: [event-loop] stall lines on nspace during payouts should disappear.
# EVENT_LOOP_STALL_LOG_MS=50

# --- Event-log analytics dashboard (wallet-auth protected) ---
# Authorized wallet(s) allowed to view `/analytics` and `/api/analytics/overview`.
# Requires Nimiq message sign-in from one of these exact wallets.
# Single-wallet (backward compatible):
# ANALYTICS_AUTHORIZED_WALLET=NQ97 4M1T 4TGD VC7F LHLQ Y2DY 425N 5CVH M02Y
# Multi-wallet (recommended): comma/semicolon/newline separated list:
# ANALYTICS_AUTHORIZED_WALLETS=NQ97 4M1T 4TGD VC7F LHLQ Y2DY 425N 5CVH M02Y, NQ16 2SSN 82TL SMQS KXT3 Q01V CMAL NU6F 1LJG
# Quoted values are also accepted:
# ANALYTICS_AUTHORIZED_WALLETS="NQ97 4M1T 4TGD VC7F LHLQ Y2DY 425N 5CVH M02Y","NQ16 2SSN 82TL SMQS KXT3 Q01V CMAL NU6F 1LJG"
# Optional manager wallet(s) allowed to manage authorized wallets from frontend/API.
# Defaults to the same list as ANALYTICS_AUTHORIZED_WALLETS when unset.
# ANALYTICS_MANAGER_WALLETS=NQ97 4M1T 4TGD VC7F LHLQ Y2DY 425N 5CVH M02Y
# Use normal Bearer JWT (wallet sign-in) with:
# - GET    /api/analytics/authorized-wallets
# - POST   /api/analytics/authorized-wallets  body: { "wallet": "NQ..." }
# - DELETE /api/analytics/authorized-wallets  body: { "wallet": "NQ..." }
# Admin add/remove is persisted to server/data/analytics-allowlist.json (survives restarts).
# Remove that file to fall back to env lists only. Optional override:
# ANALYTICS_ALLOWLIST_PATH=/var/lib/nspace/analytics-allowlist.json
# - GET    /api/analytics/page-views?days=1–90&recent=0–500  (admin: daily counts + recent beacon rows, UTC)
# - POST   /api/analytics/page-view  (browser beacon from /analytics; optional Bearer; wallet stored if allowlisted)
# Optional path for append-only JSONL of /analytics beacons (default: server/data/analytics-page-views.jsonl).
# ANALYTICS_PAGE_VIEWS_FILE=/var/lib/nspace/analytics-page-views.jsonl

# --- Game WebSocket metrics (stdout) ---
# Interval in ms for aggregated logs (outbound wire bytes + inbound raw bytes by message type). 0 = off (default).
# WS_METRICS_INTERVAL_MS=10000

# Tick snapshots: send `stateDelta` (only moved/changed avatars) when possible. Set to 0 to always send full `state` on ticks.
# STATE_BROADCAST_DELTA=0

# --- World Cup seasonal soccer (feature-flagged; deletable — grep "worldcup") ---
# Master switch. On by default; set to 0/false/off/no to disable the whole feature.
# WORLDCUP_ENABLED=1
#
# Goalies defend every goal. Behaviour model (A/B feel-test; remove the loser later):
#   kicker  = keeper is injected into the proximity-kick path and clears the ball (default)
#   blocker = keeper is a physical collider the ball reflects off
# Defaults are tuned to be BEATABLE: a well-placed corner shot scores; a tame shot down the
# middle is saved. Lower coverage / shorter kick reach / slower + laggier keeper all help the
# attacker. Raise them to make the keeper tougher.
# WORLDCUP_GOALIE_MODE=kicker
# WORLDCUP_GOALIE_MOVE_SPEED=2.5     # lateral tracking speed (units/sec; below player MOVE_SPEED 5)
# WORLDCUP_GOALIE_REACH_TENTHS=5     # keeper collision radius in tenths of a tile (5 = 0.5)
# WORLDCUP_GOALIE_REACTION_MS=260    # reaction lag locking onto the ball's z (higher = slower to react)
# WORLDCUP_GOALIE_COVERAGE_PCT=60    # % of the mouth the keeper patrols (<100 leaves corner gaps)
# WORLDCUP_GOALIE_KICK_REACH_TENTHS=3 # kicker-mode clear reach in tenths of a tile (player reach = 6)
#
# Goal rewards — Free Play Field ONLY (1v1 Matches never pay). Solo goals pay half rate;
# caps are unlimited by default — set env vars only as an emergency brake. All env-tunable:
# WORLDCUP_GOAL_REWARD_MIN_LUNA=50000           # min payout per Paid Goal (luna); 50000 = 0.5 NIM
# WORLDCUP_GOAL_REWARD_MAX_LUNA=200000          # max payout per Paid Goal (luna); 200000 = 2 NIM
# WORLDCUP_GOAL_REWARD_DAILY_CAP_PER_WALLET=0  # max Paid Goals per wallet per UTC day; 0 = unlimited
# WORLDCUP_GOAL_REWARD_DAILY_BUDGET_NIM=0       # global goal-reward budget per UTC day (NIM); 0 = unlimited
# WORLDCUP_GOAL_REWARD_MIN_PLAYERS=2           # distinct players for full rate; fewer → Solo Goal (half)
# Per-UTC-day reward counters persist to server/data/worldcup-goal-rewards.json (override path):
# WORLDCUP_GOAL_REWARDS_FILE=/var/lib/nspace/worldcup-goal-rewards.json
#
# 1v1 Match tuning:
# WORLDCUP_MATCH_COUNTDOWN_MS=3000         # handshake + 3..2..1 countdown before kickoff teleport (0 = instant)
# WORLDCUP_MATCH_DURATION_MS=180000        # regulation length (3 min)
# WORLDCUP_MATCH_GOLDEN_GOAL_CAP_MS=90000  # sudden-death cap, then a Draw
# WORLDCUP_MATCH_SPECTATOR_CAP=20          # soft cap on Spectators per Match Pitch
# WORLDCUP_CHALLENGE_TIMEOUT_MS=60000      # auto-clear a Challenge no one accepts
# WORLDCUP_MATCH_RESULT_LINGER_MS=5000     # how long the result shows before returning entrants
#
# Direct Invite (guest link/QR for 1v1; follows WORLDCUP_ENABLED unless overridden):
# DIRECT_INVITE_ENABLED=1
# DIRECT_INVITE_TTL_MS=900000          # invite lifetime from creation (default 15 min)
# GUEST_SESSION_TTL_SEC=14400          # guest JWT lifetime (default 4 hours)
# PUBLIC_BASE_URL=https://nimiq.space  # share links in invite lobby (local dev: http://localhost:3001)
# WORLDCUP_MATCH_GOAL_RESET_MS=5000        # after a (non-final) goal: reset to spawns + frozen kickoff countdown
#
# Pitch movement:
# WORLDCUP_FIELD_OUTFIELD_MARGIN=1.0       # world units a player may step past pitch edges (ball walls unchanged)
