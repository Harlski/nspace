# Server environment variables
# Copy this file to .env for local development

# REQUIRED: Secret for signing JWT tokens (use a long random string in production)
JWT_SECRET=dev-insecure-change-me

# DEVELOPMENT ONLY: Set to "1" to bypass Nimiq wallet authentication
# NEVER use this in production!
DEV_AUTH_BYPASS=1

# HTTP server port (default: 3001)
PORT=3001

# Number of NPC bots per room (0-32, default: 2)
# Set to 0 to disable NPCs
FAKE_PLAYER_COUNT=2

# Max player-owned custom rooms per wallet (1–256, default 3). Raise for subscribers / tiers later.
# MAX_OWNED_ROOMS_PER_PLAYER=3

# --- In-game feedback → Telegram (optional) ---
# Create a bot with @BotFather, add it to your group/channel, send any message in that chat,
# then read chat id from https://api.telegram.org/bot<token>/getUpdates (field result[].message.chat.id).
# Supergroup ids look like -100xxxxxxxxxx. "Bad Request: chat not found" = wrong id or bot not in chat.
#TELEGRAM_BOT_TOKEN=
#TELEGRAM_CHAT_ID=

# --- Nimiq on-chain payouts (claim rewards) ---
# Hex-encoded 32-byte private key for the hot wallet that sends NIM (never commit real keys).
# If unset, payouts stay queued and retry until configured.
#NIM_PAYOUT_PRIVATE_KEY=

# testalbatross | mainalbatross | dealbatross (see @nimiq/core ClientConfiguration.network)
#NIM_NETWORK=testnet

# Optional: override queue file dir (default: server/data next to dist)
# NIM_PAYOUT_DATA_DIR=

# Public `/api/nim/pending-payouts` completed-transactions rows (1–2000, default 20) and event-log lookback (days)
# NIM_PAYOUT_PUBLIC_HISTORY_LIMIT=20
# NIM_PAYOUT_PUBLIC_HISTORY_EVENT_DAYS=30

# Wallet-scoped pending-payouts: merge per-recipient `nim-payout-recipient-sent/*.jsonl` with this many tail lines from global `nim-payout-sent.jsonl` (older sends if the log is huge)
# NIM_PAYOUT_WALLET_GLOBAL_SENT_TAIL_LINES=250000

# Polling interval for the payout worker (ms)
# NIM_PAYOUT_PROCESS_INTERVAL_MS=8000

# HTTP GET /api/nim/payout-balance: max wait before 503 (consensus can be slow)
# NIM_BALANCE_API_TIMEOUT_MS=28000

# Skip hitting Nimiq for balance if a fresh value exists (reduces load / crashes in dev)
# NIM_BALANCE_CACHE_MS=20000

# Periodically refresh payout balance cache (ms) so block claims can use peek without mutex.
# NIM_BALANCE_BACKGROUND_REFRESH_MS=45000

# Block claim funds gate: non-zero = trust any non-null in-memory balance cache (no live await).
# Set to 0 to always await live balance on each complete (stricter, can stall behind payouts).
# NIM_CLAIM_BALANCE_PEEK_MAX_MS=30000

# Step-by-step console timeline for each payout send (mutex wait, consensus, sendTransaction, polls).
# NIM_PAYOUT_TX_TRACE=1

# How many queued payouts to attempt per wake-up (sequential, same hot wallet — keeps nonces ordered)
# NIM_PAYOUT_BURST_PER_TICK=8

# Max backoff between retries (ms)
# NIM_PAYOUT_MAX_BACKOFF_MS=3600000

# After this many failed send attempts, job moves to dead-letter file
# NIM_PAYOUT_DEAD_LETTER_ATTEMPTS=80

# Light client log level: trace|debug|info|warn|error (use error in Docker to reduce idb/autonat noise)
# NIM_CLIENT_LOG_LEVEL=warn

# Max wait for tx inclusion (ms)
# NIM_TX_CONFIRM_TIMEOUT_MS=120000

# --- Event-log analytics dashboard (wallet-auth protected) ---
# Authorized wallet(s) allowed to view `/analytics` and `/api/analytics/overview`.
# Requires Nimiq message sign-in from one of these exact wallets.
# Single-wallet (backward compatible):
# ANALYTICS_AUTHORIZED_WALLET=NQ97 4M1T 4TGD VC7F LHLQ Y2DY 425N 5CVH M02Y
# Multi-wallet (recommended): comma/semicolon/newline separated list:
# ANALYTICS_AUTHORIZED_WALLETS=NQ97 4M1T 4TGD VC7F LHLQ Y2DY 425N 5CVH M02Y, NQ16 2SSN 82TL SMQS KXT3 Q01V CMAL NU6F 1LJG
# Quoted values are also accepted:
# ANALYTICS_AUTHORIZED_WALLETS="NQ97 4M1T 4TGD VC7F LHLQ Y2DY 425N 5CVH M02Y","NQ16 2SSN 82TL SMQS KXT3 Q01V CMAL NU6F 1LJG"
# Optional manager wallet(s) allowed to manage authorized wallets from frontend/API.
# Defaults to the same list as ANALYTICS_AUTHORIZED_WALLETS when unset.
# ANALYTICS_MANAGER_WALLETS=NQ97 4M1T 4TGD VC7F LHLQ Y2DY 425N 5CVH M02Y
# Use normal Bearer JWT (wallet sign-in) with:
# - GET    /api/analytics/authorized-wallets
# - POST   /api/analytics/authorized-wallets  body: { "wallet": "NQ..." }
# - DELETE /api/analytics/authorized-wallets  body: { "wallet": "NQ..." }
# - GET    /api/analytics/page-views?days=1–90&recent=0–500  (admin: daily counts + recent beacon rows, UTC)
# - POST   /api/analytics/page-view  (browser beacon from /analytics; optional Bearer; wallet stored if allowlisted)
# Optional path for append-only JSONL of /analytics beacons (default: server/data/analytics-page-views.jsonl).
# ANALYTICS_PAGE_VIEWS_FILE=/var/lib/nspace/analytics-page-views.jsonl
