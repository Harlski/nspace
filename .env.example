# Example .env file for Docker Compose deployment
# Copy this file to .env and update the values.
#
# docker-compose.yml loads this file (repo root) and server/.env into the container.
# Shell-only exports (source .env) do NOT affect Docker — Compose reads these paths from disk.

# REQUIRED: Secure random string for JWT token signing
# Generate with: openssl rand -base64 32
JWT_SECRET=(openssl rand -base64 32)

# Optional: Number of NPC bots per room (0-32, default: 2)
FAKE_PLAYER_COUNT=2


# DO NOT set DEV_AUTH_BYPASS in production!
# DEV_AUTH_BYPASS=1

# Client chart preview: optional at Docker build — client defaults to same-origin `/nim-chart-api`.
# Override when the SPA has no nim-chart rewrite (e.g. custom host/layout).
# VITE_NIM_CHART_API_URL=https://nimiq.space/nim-chart-api
