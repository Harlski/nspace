# Example .env file for Docker Compose deployment
# Copy this file to .env and update the values.
#
# docker-compose.yml loads this file (repo root) and server/.env into the container.
# Shell-only exports (source .env) do NOT affect Docker — Compose reads these paths from disk.

# REQUIRED: Secure random string for JWT token signing
# Generate with: openssl rand -base64 32
JWT_SECRET=CHANGE_ME_TO_A_SECURE_RANDOM_STRING

# Optional: Number of NPC bots per room (0-32, default: 2)
FAKE_PLAYER_COUNT=2

# DO NOT set DEV_AUTH_BYPASS in production!
# DEV_AUTH_BYPASS=1

# Outgoing NIM payouts — Payout Service sidecar (runs by default in docker compose).
# Game server: PAYOUT_SERVICE_URL + PAYOUT_SERVICE_API_SECRET (see server/.env.example).
# Signer key NIM_PAYOUT_PRIVATE_KEY belongs ONLY on the payout service — see payout-service/.env.example.
#PAYOUT_SERVICE_API_SECRET=your-long-random-secret
#NIM_PAYOUT_PRIVATE_KEY=
#NIM_NETWORK=testalbatross

# Optional: incoming NIM payment intents (docker compose --profile payment up -d payment-intent).
# Game server probes + billboard campaigns — port 3090, not 3091 (payout).
#PAYMENT_INTENT_SERVICE_URL=http://payment-intent:3090
#PAYMENT_INTENT_API_SECRET=your-long-random-secret
#PAYMENT_INTENT_RECIPIENT_ADDRESS=NQ_...

# Client chart preview: optional at Docker build — client defaults to same-origin `/nim-chart-api`.
# Override when the SPA has no nim-chart rewrite (e.g. custom host/layout).
# VITE_NIM_CHART_API_URL=https://nimiq.space/nim-chart-api
