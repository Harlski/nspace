# Development environment variables for the client
# Copy this file to .env.development for local development

# Set to "1" to show a dev-only login (server must run with DEV_AUTH_BYPASS=1)
VITE_DEV_AUTH_BYPASS=1

# Show Admin panel (random floor layout, zoom limits)
# Layout API is currently unauthenticated — do not expose publicly
VITE_ADMIN_ENABLED=true
