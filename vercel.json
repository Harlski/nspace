{
  "framework": null,
  "installCommand": "npm ci",
  "buildCommand": "npm run build -w client",
  "outputDirectory": "client/dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://api.nimiq.space/api/:path*"
    },
    {
      "source": "/analytics",
      "destination": "https://api.nimiq.space/analytics"
    },
    {
      "source": "/admin",
      "destination": "https://api.nimiq.space/admin"
    },
    {
      "source": "/admin/system",
      "destination": "https://api.nimiq.space/admin/system"
    },
    {
      "source": "/admin/header",
      "destination": "https://api.nimiq.space/admin/header"
    },
    {
      "source": "/admin/settings",
      "destination": "https://api.nimiq.space/admin/settings"
    },
    {
      "source": "/admin/feedback",
      "destination": "https://api.nimiq.space/admin/feedback"
    },
    {
      "source": "/admin/campaign",
      "destination": "https://api.nimiq.space/admin/campaign"
    },
    {
      "source": "/admin/bans",
      "destination": "https://api.nimiq.space/admin/bans"
    },
    {
      "source": "/admin/rooms",
      "destination": "https://api.nimiq.space/admin/rooms"
    },
    {
      "source": "/advertise/uploads/:path*",
      "destination": "https://api.nimiq.space/advertise/uploads/:path*"
    },
    {
      "source": "/advertise/how-it-works",
      "destination": "https://api.nimiq.space/advertise/how-it-works"
    },
    {
      "source": "/advertise",
      "destination": "https://api.nimiq.space/advertise"
    },
    {
      "source": "/payouts",
      "destination": "https://api.nimiq.space/payouts"
    },
    {
      "source": "/pending-payouts",
      "destination": "https://api.nimiq.space/payouts"
    },
    {
      "source": "/nim-chart-api/:path*",
      "destination": "https://api.nimiq.space/nim-chart-api/:path*"
    },
    {
      "source": "/pixels.png",
      "destination": "https://api.nimiq.space/pixels.png"
    },
    {
      "source": "/join/:slug",
      "destination": "/index.html"
    },
    {
      "source": "/patchnotes",
      "destination": "/index.html"
    },
    {
      "source": "/patchnotes/",
      "destination": "/index.html"
    },
    {
      "source": "/tacs",
      "destination": "/tacs.html"
    },
    {
      "source": "/tacs/",
      "destination": "/tacs.html"
    },
    {
      "source": "/privacy",
      "destination": "/privacy.html"
    },
    {
      "source": "/privacy/",
      "destination": "/privacy.html"
    }
  ],
  "redirects": [
    {
      "source": "/tac",
      "destination": "/tacs",
      "permanent": true
    },
    {
      "source": "/tac/",
      "destination": "/tacs",
      "permanent": true
    }
  ]
}
